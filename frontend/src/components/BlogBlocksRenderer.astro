---
import type { BlogBlock } from "@/types/content";

interface Props {
  blocks: BlogBlock[];
}

const { blocks } = Astro.props;
---

<div class="space-y-6">
  {
    blocks.map((block) => {
      if (block.type === "heading") {
        return block.level === 2 ? (
          <h2 class="text-2xl font-semibold text-brandDark">{block.text}</h2>
        ) : (
          <h3 class="text-xl font-semibold text-brandDark">{block.text}</h3>
        );
      }

      if (block.type === "paragraph") {
        return <p class="text-base leading-8 text-gray-700">{block.text}</p>;
      }

      if (block.type === "quote") {
        return (
          <blockquote class="rounded-xl border-l-4 border-brandOrange bg-gray-50 p-5 italic text-gray-700">
            <p>{block.text}</p>
            {block.cite && <cite class="mt-3 block text-sm not-italic text-gray-500">- {block.cite}</cite>}
          </blockquote>
        );
      }

      if (block.type === "list") {
        return block.style === "ordered" ? (
          <ol class="list-decimal space-y-2 pl-5 text-base leading-7 text-gray-700">
            {block.items.map((item) => <li>{item}</li>)}
          </ol>
        ) : (
          <ul class="list-disc space-y-2 pl-5 text-base leading-7 text-gray-700">
            {block.items.map((item) => <li>{item}</li>)}
          </ul>
        );
      }

      return (
        <figure class="overflow-hidden rounded-xl border border-gray-200">
          <img src={block.src} alt={block.alt} class="w-full object-cover" loading="lazy" />
          {block.caption && <figcaption class="border-t border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-600">{block.caption}</figcaption>}
        </figure>
      );
    })
  }
</div>

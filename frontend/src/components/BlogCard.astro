---
import type { BlogPost } from "@/types/content";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const publishedLabel = new Date(post.publishedAt).toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric"
});
---

<article class="flex h-full flex-col overflow-hidden rounded-xl bg-white shadow-lg transition hover:-translate-y-1 hover:shadow-xl">
  <a href={`/blog/${post.slug}`} class="block">
    <div class="relative aspect-[16/10] w-full overflow-hidden">
      <div
        class="card-media-bg absolute inset-0 h-full w-full object-cover"
        style={`--card-image: url('${post.coverImage}');`}
        role="img"
        aria-label={post.coverImageAlt}
      ></div>
    </div>
  </a>
  <div class="flex h-full flex-col p-5">
    <div class="flex flex-wrap items-center gap-2 text-xs text-gray-500">
      <span class="rounded-full bg-amber-100 px-2 py-1 font-semibold text-amber-800">{post.category}</span>
      <span>{publishedLabel}</span>
      <span>&bull;</span>
      <span>{post.readingTimeMinutes} min read</span>
    </div>
    <p class="mt-3 text-xl font-semibold text-brandDark">
      <a href={`/blog/${post.slug}`} class="transition hover:text-brandOrange">{post.title}</a>
    </p>
    <p class="mt-2 text-sm text-gray-700">{post.excerpt}</p>
    <p class="mt-3 text-xs text-gray-500">By {post.author}</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {
        post.tags.slice(0, 3).map((tag) => (
          <span class="inline-flex rounded-full border border-sky-300 bg-sky-200 px-3 py-1 text-xs font-semibold tracking-wide text-sky-900">
            {tag}
          </span>
        ))
      }
    </div>
    <a href={`/blog/${post.slug}`} class="mt-auto pt-5 text-sm font-semibold text-brandOrange transition hover:text-brandDark">
      Read article &rarr;
    </a>
  </div>
</article>

---
interface Props {
  mode: "tour" | "transfer";
}

const { mode } = Astro.props;
---

<form id={`${mode}Form`} class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
  <h3 class="text-lg font-semibold text-brandDark">{mode === "tour" ? "Tour Booking Request" : "Transfer Request"}</h3>
  <div class="mt-4 grid gap-3 md:grid-cols-2">
    <label class="text-sm">
      Full Name
      <input required name="name" class="mt-1 w-full rounded-md border border-gray-300 p-2" />
    </label>
    <label class="text-sm">
      Email
      <input required type="email" name="email" class="mt-1 w-full rounded-md border border-gray-300 p-2" />
    </label>
    <label class="text-sm">
      Phone / WhatsApp
      <input required name="phone" class="mt-1 w-full rounded-md border border-gray-300 p-2" />
    </label>
    <label class="text-sm">
      Date
      <input required type="date" name="date" class="mt-1 w-full rounded-md border border-gray-300 p-2" />
    </label>
  </div>
  <label class="mt-3 block text-sm">
    Details
    <textarea name="details" rows="4" class="mt-1 w-full rounded-md border border-gray-300 p-2"></textarea>
  </label>
  <div class="mt-4 flex flex-wrap gap-2">
    <button data-channel="mailto" class="rounded-full border border-brandOrange px-4 py-2 text-sm font-semibold text-brandOrange">Send by Email</button>
    <button data-channel="whatsapp" class="rounded-full bg-brandOrange px-4 py-2 text-sm font-semibold text-white">
      Send by WhatsApp
    </button>
  </div>
</form>

<script>
  const forms = document.querySelectorAll<HTMLFormElement>("form[id$='Form']");
  for (const form of forms) {
    const buttons = form.querySelectorAll<HTMLButtonElement>("button[data-channel]");
    for (const button of buttons) {
      button.addEventListener("click", (event) => {
        event.preventDefault();
        if (!form.reportValidity()) return;
        const data = Object.fromEntries(new FormData(form).entries());
        const mode = form.id.replace("Form", "");
        const subject = `Booking Request (${mode})`;
        const body = Object.entries(data)
          .map(([k, v]) => `${k}: ${String(v)}`)
          .join("\n");
        const channel = button.getAttribute("data-channel");
        let target = "";
        if (channel === "mailto") {
          target = `mailto:discoverkutaisi@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        }
        if (channel === "whatsapp") {
          target = `https://api.whatsapp.com/send?phone=+995557669179&text=${encodeURIComponent(body)}`;
        }
        window.open(target, "_blank", "noopener,noreferrer");
      });
    }
  }
</script>

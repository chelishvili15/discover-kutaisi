---
import { site } from "@/data/site";

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalPath?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  twitterCard?: string;
}

const {
  title,
  description,
  image = "/content/img/hero.jpg",
  canonicalPath = "/",
  ogTitle = title,
  ogDescription = description,
  ogImage = image,
  ogType = "website",
  twitterCard = "summary_large_image"
} = Astro.props;
const canonicalUrl = new URL(canonicalPath, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const normalizedTitle = title.trim().toLowerCase();
const brandName = "Discover Kutaisi";
const pageTitle = normalizedTitle.includes(brandName.toLowerCase()) ? title : `${title} | ${brandName}`;
---

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="icon" type="image/svg+xml" href={site.logoPath} />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={site.name} />
<meta property="og:title" content={ogTitle} />
<meta property="og:description" content={ogDescription} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:url" content={canonicalUrl} />
<meta name="twitter:card" content={twitterCard} />
<meta name="twitter:title" content={ogTitle} />
<meta name="twitter:description" content={ogDescription} />
<meta name="twitter:image" content={ogImageUrl} />
<link rel="canonical" href={canonicalUrl} />


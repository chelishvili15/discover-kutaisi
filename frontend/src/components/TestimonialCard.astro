---
import type { Testimonial } from "@/types/content";
interface Props {
  item: Testimonial;
}
const { item } = Astro.props;

const words = item.name.trim().split(/\s+/).filter(Boolean);
const initials = words[0]?.[0] ?? "";
const avatarStyles = [
  "bg-[#1A73E8] text-white",
  "bg-[#34A853] text-white",
  "bg-[#EA4335] text-white",
  "bg-[#FBBC04] text-[#202124]",
  "bg-[#A142F4] text-white",
  "bg-[#5F6368] text-white"
];
const hash = item.name.split("").reduce((acc, ch) => acc + ch.charCodeAt(0), 0);
const avatarClass = avatarStyles[hash % avatarStyles.length];
---

<article class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
  <div class="mb-3 flex items-center">
    <div class="flex items-center gap-3">
      {
        item.avatarImage ? (
          <img
            src={item.avatarImage}
            alt={item.avatarAlt ?? `${item.name} profile image`}
            class="h-10 w-10 shrink-0 rounded-full object-cover"
            loading="lazy"
            decoding="async"
          />
        ) : (
          <div class={`inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-base font-medium uppercase leading-none ${avatarClass}`}>
            {initials}
          </div>
        )
      }
      <p class="text-sm font-semibold text-brandDark">{item.name}</p>
    </div>
  </div>
  <p class="text-sm text-gray-700">"{item.quote}"</p>
  <p class="mt-3 text-sm text-brandOrange" aria-label={`${item.rating} out of 5 stars`}>
    {
      Array.from({ length: item.rating }).map(() => (
        <span aria-hidden="true">&starf;</span>
      ))
    }
  </p>
</article>

---
import type { Tour } from "@/types/content";
import { formatUsdGel } from "@/lib/currency";

interface Props {
  tour: Tour;
}

const { tour } = Astro.props;
---

<article class="flex h-full flex-col overflow-hidden rounded-xl bg-white shadow-lg transition hover:-translate-y-1 hover:shadow-xl">
  <div class="relative aspect-[16/10] w-full overflow-hidden">
    <div
      class="card-media-bg absolute inset-0 block h-full w-full object-cover object-center"
      style={`--card-image: url('${tour.image}');`}
      role="img"
      aria-label={tour.title}
    ></div>
  </div>
  <div class="flex h-full flex-col p-5">
    <p class="text-xl font-semibold text-brandDark">
      <a href={`/tours/${tour.slug}`} class="transition hover:text-brandOrange">
        {tour.title}
      </a>
    </p>
    <p class="mt-1 text-sm text-gray-600">
      Duration: {tour.durationLabel} &bull; {tour.difficulty}
    </p>
    <p class="mt-2 text-sm text-gray-700">{tour.summary}</p>
    <p class="mt-3 text-sm">
      <span class="text-gray-900">From:</span>
      <span class="font-semibold text-brandOrange"> {formatUsdGel(tour.priceFromGel)}</span>
      <span class="text-gray-700"> per person</span>
    </p>
    <a
      href={`/tours/${tour.slug}`}
      class="mt-auto inline-block w-fit rounded-full bg-brandOrange px-5 py-2 text-sm font-semibold text-white"
    >
      Book Now
    </a>
  </div>
</article>

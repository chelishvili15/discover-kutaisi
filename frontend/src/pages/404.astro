---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found" description="The requested page could not be found." canonicalPath="/404">
  <section
    class="hero-bg hero-image-default hero-overlay-55 relative overflow-hidden py-24"
    
  >
    <div class="container-shell relative text-center text-white">
      <h1 class="text-5xl font-bold">Page Not Found in Kutaisi</h1>
      <p class="mt-4 text-gray-100">This page does not exist.</p>
      <a href="/" class="mt-8 inline-block rounded-full bg-brandOrange px-6 py-3 text-white">Go Home</a>
    </div>
  </section>
</BaseLayout>


---
import BaseLayout from "@/layouts/BaseLayout.astro";
import StructuredData from "@/components/StructuredData.astro";
import { aboutPage } from "@/data/pages";
import { icons } from "@/data/icons";
import { site } from "@/data/site";
import { buildBreadcrumbSchema, buildOrganizationSchema, toAbsoluteUrl } from "@/lib/seo";

const { seo, content } = aboutPage;
const paragraphs = content.paragraphs ?? [];

const intro = paragraphs[0] ?? "";
const teamAndComfort = paragraphs[1] ?? "";
const planningAndTransfers = paragraphs[2] ?? "";
const closingLine = paragraphs[3] ?? "";
const siteUrl = `https://${site.domain}`;
const canonicalUrl = toAbsoluteUrl(seo.canonicalPath, siteUrl);
const organizationSchema = buildOrganizationSchema(site, siteUrl);
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Home", url: siteUrl },
  { name: "About", url: canonicalUrl }
]);
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonicalPath={seo.canonicalPath}
  image={seo.image}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  ogImage={seo.ogImage}
>
  <StructuredData data={[organizationSchema, breadcrumbSchema]} />
  <section
    class="hero-bg hero-image-default hero-overlay-45 relative overflow-hidden py-20"
    
  >
    <div class="container-shell relative text-white">
      <h1 class="section-title !text-white">{content.heroTitle}</h1>
      <p class="mt-3 max-w-2xl text-sm text-gray-100">
        {content.heroSubtitle}
      </p>
    </div>
  </section>

  <section class="container-shell py-12">
    <article class="rounded-xl border border-gray-200 bg-white p-6">
      <div class="flex items-center gap-3">
        <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center">
          <img src={icons.about.whoWeAre} alt="" class="h-5 w-5 object-contain" loading="lazy" aria-hidden="true" />
        </span>
        <h2 class="text-2xl font-semibold text-brandDark">{content.whoWeAreTitle}</h2>
      </div>
      <p class="mt-3 text-sm leading-7 text-gray-700">{intro}</p>
    </article>

    <div class="mt-8 grid gap-8 md:grid-cols-2">
      <article class="rounded-xl border border-gray-200 bg-white p-6">
        <div class="flex items-center gap-3">
          <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center">
            <img src={icons.about.team} alt="" class="h-5 w-5 object-contain" loading="lazy" aria-hidden="true" />
          </span>
          <h2 class="text-xl font-semibold text-brandDark">{content.teamTitle}</h2>
        </div>
        <p class="mt-3 text-sm leading-7 text-gray-700">{teamAndComfort}</p>
      </article>
      <article class="rounded-xl border border-gray-200 bg-white p-6">
        <div class="flex items-center gap-3">
          <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center">
            <img src={icons.about.planning} alt="" class="h-5 w-5 object-contain" loading="lazy" aria-hidden="true" />
          </span>
          <h2 class="text-xl font-semibold text-brandDark">{content.planningTitle}</h2>
        </div>
        <p class="mt-3 text-sm leading-7 text-gray-700">{planningAndTransfers}</p>
      </article>
    </div>

    <article class="mt-8 rounded-xl border border-gray-200 bg-white p-6 text-center">
      <div class="mt-3 flex justify-center">
        <span class="inline-flex rounded-full border border-amber-300 bg-amber-200 px-3 py-1 text-xs font-semibold tracking-wide text-amber-900">
          {closingLine || content.ctaTag}
        </span>
      </div>
      <div class="mt-3 flex items-center justify-center gap-3">
        <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center">
          <img src={icons.about.cta} alt="" class="h-5 w-5 object-contain" loading="lazy" aria-hidden="true" />
        </span>
        <h2 class="text-xl font-semibold text-brandDark">{content.ctaTitle}</h2>
      </div>
      <p class="mt-2 text-sm leading-7 text-gray-700">
        {content.ctaDescription}
      </p>
      <div class="mt-5 flex justify-center">
        <a href="/contact" class="inline-block rounded-full bg-brandOrange px-6 py-3 text-sm font-semibold text-white">
          {content.ctaButtonLabel}
        </a>
      </div>
    </article>

    {
      paragraphs.length > 4 && (
        <article class="mt-6 rounded-xl border border-gray-200 bg-white p-6">
          <div class="space-y-4">
            {paragraphs.slice(4).map((paragraph) => (
              <p class="text-sm leading-7 text-gray-700">{paragraph}</p>
            ))}
          </div>
        </article>
      )
    }
  </section>
</BaseLayout>


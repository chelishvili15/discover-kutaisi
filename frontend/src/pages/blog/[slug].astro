---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogBlocksRenderer from "@/components/BlogBlocksRenderer.astro";
import BlogCard from "@/components/BlogCard.astro";
import ShareActions from "@/components/ShareActions.astro";
import StructuredData from "@/components/StructuredData.astro";
import { publishedBlogPosts } from "@/data/blog";
import { site } from "@/data/site";
import { buildBlogPostingSchema, buildBreadcrumbSchema, toAbsoluteUrl } from "@/lib/seo";

export function getStaticPaths() {
  return publishedBlogPosts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const siteUrl = `https://${site.domain}`;
const canonicalUrl = toAbsoluteUrl(post.seo.canonicalPath, siteUrl);
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Home", url: siteUrl },
  { name: "Blog", url: toAbsoluteUrl("/blog", siteUrl) },
  { name: post.title, url: canonicalUrl }
]);
const blogPostingSchema = buildBlogPostingSchema(post, canonicalUrl);
const relatedPosts = publishedBlogPosts
  .filter((item) => item.slug !== post.slug && item.category === post.category)
  .slice(0, 3);
const publishedLabel = new Date(post.publishedAt).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric"
});
---

<BaseLayout
  title={post.seo.title}
  description={post.seo.description}
  canonicalPath={post.seo.canonicalPath}
  image={post.seo.image}
  ogTitle={post.seo.ogTitle}
  ogDescription={post.seo.ogDescription}
  ogImage={post.seo.ogImage}
  ogType="article"
>
  <StructuredData data={[breadcrumbSchema, blogPostingSchema]} />
  <section
    class="hero-bg hero-overlay-50 relative overflow-hidden py-20"
    style={`--hero-image: url('${post.coverImage}');`}
  >
    <div class="container-shell relative text-white">
      <h1 class="max-w-3xl text-4xl font-semibold">{post.title}</h1>
      <p class="mt-3 text-sm text-gray-100">
        {post.category} &bull; {publishedLabel} &bull; By {post.author} &bull; {post.readingTimeMinutes} min read
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        {
          post.tags.map((tag) => (
            <span class="inline-flex rounded-full border border-sky-300 bg-sky-200 px-3 py-1 text-xs font-semibold tracking-wide text-sky-900">
              {tag}
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <section class="container-shell py-12">
    <article class="mx-auto max-w-4xl rounded-xl border border-gray-200 bg-white p-6 md:p-10">
      <img src={post.coverImage} alt={post.coverImageAlt} class="mb-8 h-auto w-full rounded-xl object-cover" loading="eager" />
      <BlogBlocksRenderer blocks={post.contentBlocks} />
      <div class="mt-8">
        <ShareActions url={canonicalUrl} title={post.title} />
      </div>
    </article>
  </section>

  {
    relatedPosts.length > 0 && (
      <section class="container-shell py-2">
        <h2 class="text-2xl font-semibold text-brandDark">Related Articles</h2>
        <div class="mt-6 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {relatedPosts.map((item) => <BlogCard post={item} />)}
        </div>
      </section>
    )
  }
</BaseLayout>

---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogCard from "@/components/BlogCard.astro";
import StructuredData from "@/components/StructuredData.astro";
import { BLOG_PAGE_SIZE, publishedBlogPosts } from "@/data/blog";
import { site } from "@/data/site";
import { buildBlogItemListSchema, buildBreadcrumbSchema, toAbsoluteUrl } from "@/lib/seo";

const siteUrl = `https://${site.domain}`;
const posts = publishedBlogPosts.slice(0, BLOG_PAGE_SIZE);
const hasNextPage = publishedBlogPosts.length > BLOG_PAGE_SIZE;
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Home", url: siteUrl },
  { name: "Blog", url: toAbsoluteUrl("/blog", siteUrl) }
]);
const itemListSchema = buildBlogItemListSchema(posts, siteUrl);
---

<BaseLayout
  title="Discover Kutaisi Blog"
  description="Travel guides, destination tips, and practical advice for exploring Kutaisi and Western Georgia."
  canonicalPath="/blog"
  image="/content/img/hero.jpg"
  ogTitle="Discover Kutaisi Blog"
  ogDescription="Travel guides, destination tips, and practical advice for exploring Kutaisi and Western Georgia."
  ogImage="/content/img/hero.jpg"
>
  <StructuredData data={[breadcrumbSchema, itemListSchema]} />
  <section
    class="hero-bg hero-image-default hero-overlay-45 relative overflow-hidden py-20"
    
  >
    <div class="container-shell relative text-white">
      <h1 class="section-title !text-white">Discover Kutaisi Blog</h1>
      <p class="mt-3 max-w-2xl text-sm text-gray-100">
        Local travel guides, itinerary ideas, and practical tips for planning your trip in Western Georgia.
      </p>
    </div>
  </section>

  <section class="container-shell py-12">
    {
      posts.length > 0 ? (
        <>
          <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            {posts.map((post) => <BlogCard post={post} />)}
          </div>
          {hasNextPage && (
            <div class="mt-10 flex justify-end">
              <a href="/blog/page/2" class="rounded-full bg-brandOrange px-5 py-2 text-sm font-semibold text-white">
                Next Page &rarr;
              </a>
            </div>
          )}
        </>
      ) : (
        <article class="rounded-xl border border-gray-200 bg-white p-6 text-sm text-gray-600">
          No blog posts are published yet.
        </article>
      )
    }
  </section>
</BaseLayout>


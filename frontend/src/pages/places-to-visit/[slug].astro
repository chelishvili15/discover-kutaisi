---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ShareActions from "@/components/ShareActions.astro";
import StructuredData from "@/components/StructuredData.astro";
import { icons } from "@/data/icons";
import { places } from "@/data/places";
import { site } from "@/data/site";
import { formatUsdGel } from "@/lib/currency";
import { buildBreadcrumbSchema, buildTouristAttractionSchema, toAbsoluteUrl } from "@/lib/seo";
import "photoswipe/style.css";

export function getStaticPaths() {
  return places.map((place) => ({ params: { slug: place.slug }, props: { place } }));
}

const { place } = Astro.props;
const galleryImages: string[] = place.images ?? [];
const normalizeOverviewText = (value: string): string => value.replace(/\s*\r?\n+\s*/g, " ").trim();
const placeDescription = normalizeOverviewText(place.description);
const feePattern = /(\d+)\s*(?:GEL\b|\u20BE)/gi;
const formatFeeText = (value: string): string =>
  value.replace(feePattern, (gelText) => {
    const gel = Number.parseInt(gelText, 10);
    return Number.isNaN(gel) ? gelText : `${formatUsdGel(gel)} per person`;
  });
const entryFeeLabel = formatFeeText(place.entryFee);
const activityFeeLabels = place.activities.map((activity: string) => formatFeeText(activity));
const siteUrl = `https://${site.domain}`;
const canonicalUrl = toAbsoluteUrl(place.seo.canonicalPath, siteUrl);
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Home", url: siteUrl },
  { name: "Places to Visit", url: toAbsoluteUrl("/places-to-visit", siteUrl) },
  { name: place.name, url: canonicalUrl }
]);
const attractionSchema = buildTouristAttractionSchema(place, canonicalUrl);
const heroHeading = place.name.trim().length < 20 ? `${place.name} in Georgia` : place.name;

const youtubeEmbedUrl = (() => {
  if (!place.videoUrl) return null;
  try {
    const url = new URL(place.videoUrl);
    let videoId = "";

    if (url.hostname.includes("youtu.be")) {
      videoId = url.pathname.split("/").filter(Boolean)[0] ?? "";
    } else if (url.hostname.includes("youtube.com")) {
      if (url.pathname === "/watch") {
        videoId = url.searchParams.get("v") ?? "";
      } else if (url.pathname.startsWith("/embed/") || url.pathname.startsWith("/shorts/")) {
        videoId = url.pathname.split("/")[2] ?? "";
      }
    }

    if (!videoId) return null;
    const params = new URLSearchParams({
      autoplay: "1",
      mute: "1",
      playsinline: "1",
      rel: "0"
    });
    return `https://www.youtube.com/embed/${videoId}?${params.toString()}`;
  } catch {
    return null;
  }
})();
---

<BaseLayout
  title={place.seo.title}
  description={place.seo.description}
  canonicalPath={place.seo.canonicalPath}
  image={place.seo.image}
  ogTitle={place.seo.ogTitle}
  ogDescription={place.seo.ogDescription}
  ogImage={place.seo.ogImage}
>
  <StructuredData data={[breadcrumbSchema, attractionSchema]} />
  <section
    class="hero-bg hero-image-default hero-overlay-40 relative overflow-hidden py-20"
    
  >
    <div class="container-shell relative text-white">
      <h1 class="text-4xl font-semibold">{heroHeading}</h1>
      <p class="mt-2 text-sm">{place.location} &bull; Entry: {entryFeeLabel}</p>
      <p class="mt-2 max-w-3xl text-sm leading-7 text-gray-100">{placeDescription}</p>
    </div>
  </section>

  <section class="container-shell pb-6 pt-8">
    <article class="rounded-xl border border-gray-200 bg-white p-6">
      <div class="flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center">
            <img src={icons.placeDetail.gallery} alt="" class="h-5 w-5 object-contain" loading="lazy" aria-hidden="true" />
          </span>
          <h2 class="text-2xl font-semibold text-brandDark">Image Gallery</h2>
        </div>
        <span id="galleryCounter" class="rounded-full border border-gray-200 px-3 py-1 text-xs font-semibold text-gray-600">
          1 / {Math.max(galleryImages.length, 1)}
        </span>
      </div>

      <div class="mt-5 relative overflow-hidden rounded-xl border border-gray-200">
        <button
          id="galleryPrev"
          type="button"
          class="absolute left-3 top-1/2 z-10 -translate-y-1/2 rounded-full bg-black/65 p-2 text-white transition hover:bg-black/80"
          aria-label="Previous image"
        >
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" aria-hidden="true">
            <path d="m15 18-6-6 6-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>

        <button id="galleryOpen" type="button" class="block w-full" aria-label="Open image in fullscreen">
          <img
            id="galleryImage"
            src={galleryImages[0] ?? "/content/img/hero.jpg"}
            alt={place.name}
            class="h-[320px] w-full cursor-zoom-in object-cover md:h-[500px]"
            loading="eager"
          />
        </button>

        <button
          id="galleryNext"
          type="button"
          class="absolute right-3 top-1/2 z-10 -translate-y-1/2 rounded-full bg-black/65 p-2 text-white transition hover:bg-black/80"
          aria-label="Next image"
        >
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" aria-hidden="true">
            <path d="m9 18 6-6-6-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
      <p class="mt-3 text-xs text-gray-500">Use arrows to browse photos. Click image to zoom.</p>

    </article>
  </section>

  <section class="container-shell pb-8 pt-0">
    <div class="space-y-6">
      {
        place.activities.length > 0 && (
          <article class="rounded-xl border border-gray-200 bg-white p-6">
          <div class="flex items-center gap-3">
            <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center">
              <img src={icons.placeDetail.activities} alt="" class="h-5 w-5 object-contain" loading="lazy" aria-hidden="true" />
            </span>
            <h2 class="text-xl font-semibold text-brandDark">Activities & Fees</h2>
          </div>
          <ul class="mt-4 space-y-2 text-sm text-gray-700">
            {activityFeeLabels.map((activity) => (
              <li class="rounded-lg border border-gray-100 px-3 py-2">{activity}</li>
            ))}
          </ul>
          </article>
        )
      }

      {
        place.details.length > 0 && (
          <article class="rounded-xl border border-gray-200 bg-white p-6">
          <div class="flex items-center gap-3">
            <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center">
              <img src={icons.placeDetail.details} alt="" class="h-5 w-5 object-contain" loading="lazy" aria-hidden="true" />
            </span>
            <h2 class="text-xl font-semibold text-brandDark">Detailed Information</h2>
          </div>
          <div class="mt-4 space-y-4">
            {place.details.map((paragraph) => (
              <p class="text-sm leading-7 text-gray-700">{paragraph}</p>
            ))}
          </div>
          </article>
        )
      }

      {
        youtubeEmbedUrl && (
          <article class="rounded-xl border border-gray-200 bg-white p-6">
          <div class="flex items-center gap-3">
            <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center">
              <img src={icons.placeDetail.video} alt="" class="h-5 w-5 object-contain" loading="lazy" aria-hidden="true" />
            </span>
            <h2 class="text-xl font-semibold text-brandDark">Video</h2>
          </div>
          <div class="mt-4 overflow-hidden rounded-xl border border-gray-200">
            <div class="w-full">
              <iframe
                class="h-[360px] w-full md:h-[560px] lg:h-[760px]"
                src={youtubeEmbedUrl}
                title={`Video about ${place.name}`}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                referrerpolicy="strict-origin-when-cross-origin"
                allowfullscreen
              ></iframe>
            </div>
          </div>
          </article>
        )
      }
    </div>
    <div id="placeGalleryData" data-images={JSON.stringify(galleryImages)} data-place-name={place.name} class="hidden"></div>
    <div class="mt-6">
      <ShareActions url={canonicalUrl} title={place.name} />
    </div>
  </section>

  <script>
    import PhotoSwipeLightbox from "photoswipe/lightbox";

    const galleryImage = document.getElementById("galleryImage");
    const galleryCounter = document.getElementById("galleryCounter");
    const galleryPrev = document.getElementById("galleryPrev");
    const galleryNext = document.getElementById("galleryNext");
    const galleryOpen = document.getElementById("galleryOpen");
    const galleryData = document.getElementById("placeGalleryData");
    const imagesRaw = galleryData?.getAttribute("data-images") ?? "[]";
    const placeName = galleryData?.getAttribute("data-place-name") ?? "Place";

    let parsedImages = [];
    try {
      const parsed = JSON.parse(imagesRaw);
      parsedImages = Array.isArray(parsed) ? parsed : [];
    } catch {
      parsedImages = [];
    }

    const images = parsedImages.filter((item) => typeof item === "string" && item.length > 0);

    let index = 0;

    const updateImage = () => {
      if (!images.length || !galleryImage || !galleryCounter) return;
      const src = images[index];
      const alt = `${placeName} image ${index + 1}`;
      galleryImage.setAttribute("src", src);
      galleryImage.setAttribute("alt", alt);
      galleryCounter.textContent = `${index + 1} / ${images.length}`;
    };

    const prev = () => {
      if (!images.length) return;
      index = (index - 1 + images.length) % images.length;
      updateImage();
    };

    const next = () => {
      if (!images.length) return;
      index = (index + 1) % images.length;
      updateImage();
    };

    const lightbox = new PhotoSwipeLightbox({
      dataSource: images.map((src, itemIndex) => ({
        src,
        width: 1600,
        height: 1067,
        alt: `${placeName} image ${itemIndex + 1}`
      })),
      bgOpacity: 0.85,
      showHideAnimationType: "zoom",
      pswpModule: () => import("photoswipe")
    });
    if (images.length) lightbox.init();

    galleryPrev?.addEventListener("click", prev);
    galleryNext?.addEventListener("click", next);
    galleryOpen?.addEventListener("click", (event) => {
      event.preventDefault();
      if (!images.length) return;
      lightbox.loadAndOpen(index);
    });
    galleryImage?.addEventListener("click", () => {
      if (!images.length) return;
      lightbox.loadAndOpen(index);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "ArrowLeft") prev();
      if (event.key === "ArrowRight") next();
    });

    if (!images.length) {
      galleryPrev?.setAttribute("disabled", "true");
      galleryNext?.setAttribute("disabled", "true");
    }

    updateImage();
  </script>
</BaseLayout>

---
// Clean slate layout
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Flawless QR Code Generator</title>
  <!-- Load the stable matrix-only generator via CDN -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/qrcode-generator/1.4.4/qrcode.min.js"></script>
</head>
<body>

  <div class="container">
    <!-- Left Panel: Controls & Inputs -->
    <div class="left-panel">
      <div class="input-group">
        <label for="qr-text" class="preview-label">Enter Text or URL</label>
        <input 
          type="text" 
          id="qr-text" 
          placeholder="https://example.com" 
          value="https://example.com"
        />
      </div>

      <div class="style-group">
        <span class="preview-label">Dot Style</span>
        <div class="style-buttons">
          <button type="button" class="style-btn active" data-style="square" title="Square">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
          </button>
          
          <button type="button" class="style-btn" data-style="circle" title="Circle">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>
          </button>
          
          <button type="button" class="style-btn" data-style="star" title="Star">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
          </button>
        </div>
      </div>

      <button id="download-btn" class="download-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download SVG
      </button>
    </div>

    <!-- Right Panel: Live Preview -->
    <div class="right-panel">
      <span class="preview-label">Live Preview</span>
      
      <div class="qr-preview-wrapper">
        <div id="canvas-container" class="qr-preview"></div>
        
        <div id="placeholder" class="qr-placeholder hidden">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="5" height="5" x="3" y="3" rx="1"/><rect width="5" height="5" x="16" y="3" rx="1"/><rect width="5" height="5" x="3" y="16" rx="1"/><path d="M21 16V10H16V15H21V16Z"/><path d="M12 3V7H10V3H12Z"/></svg>
          <p>Enter text above to generate a live QR code preview.</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    window.addEventListener('DOMContentLoaded', () => {
      const inputEl = document.getElementById('qr-text');
      const downloadBtn = document.getElementById('download-btn');
      const containerEl = document.getElementById('canvas-container');
      const placeholderEl = document.getElementById('placeholder');
      const styleButtons = document.querySelectorAll('.style-btn');

      let currentStyle = 'square';
      let globalSvgMarkup = '';

      function generateCustomQR() {
        const textValue = inputEl.value.trim();
        
        if (textValue === '') {
          containerEl.classList.add('hidden');
          placeholderEl.classList.remove('hidden');
          return;
        }

        placeholderEl.classList.add('hidden');
        containerEl.classList.remove('hidden');

        // Type 0 auto-detects minimum matrix size required, Error correction 'M'
        const qr = qrcode(0, 'M');
        qr.addData(textValue);
        qr.make();

        const moduleCount = qr.getModuleCount();
        const cellSize = 10;
        const margin = 20;
        const size = moduleCount * cellSize + margin * 2;

        let svgContent = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ${size} ${size}" width="100%" height="100%">`;
        // Clean white background wrapper
        svgContent += `<rect width="${size}" height="${size}" fill="#ffffff"/>`;
        svgContent += `<g fill="#000000">`;

        for (let row = 0; row < moduleCount; row++) {
          for (let col = 0; col < moduleCount; col++) {
            if (qr.isDark(row, col)) {
              const x = margin + col * cellSize;
              const y = margin + row * cellSize;

              // Keep position detection patterns cleanly structured as squares for readability
              const isFinderPattern = (row < 7 && col < 7) || (row < 7 && col >= moduleCount - 7) || (row >= moduleCount - 7 && col < 7);

              if (isFinderPattern || currentStyle === 'square') {
                svgContent += `<rect x="${x}" y="${y}" width="${cellSize}" height="${cellSize}"/>`;
              } else if (currentStyle === 'circle') {
                const cx = x + cellSize / 2;
                const cy = y + cellSize / 2;
                svgContent += `<circle cx="${cx}" cy="${cy}" r="${cellSize * 0.45}"/>`;
              } else if (currentStyle === 'star') {
                const cx = x + cellSize / 2;
                const cy = y + cellSize / 2;
                // Elegant 4-point star path centered perfectly on the matrix cell coordinate
                svgContent += `<path d="M ${cx} ${y} L ${x + cellSize*0.68} ${y + cellSize*0.32} L ${x + cellSize} ${cy} L ${x + cellSize*0.68} ${y + cellSize*0.68} L ${cx} ${y + cellSize} L ${x + cellSize*0.32} ${y + cellSize*0.68} L ${x} ${cy} L ${x + cellSize*0.32} ${y + cellSize*0.32} Z"/>`;
              }
            }
          }
        }

        svgContent += `</g></svg>`;
        globalSvgMarkup = svgContent;
        containerEl.innerHTML = svgContent;
      }

      // Live updates
      inputEl.addEventListener('input', generateCustomQR);

      styleButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          styleButtons.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          currentStyle = btn.getAttribute('data-style');
          generateCustomQR();
        });
      });

      // Flawless local SVG download handler
      downloadBtn.addEventListener('click', () => {
        if (!globalSvgMarkup) return;
        
        const blob = new Blob([globalSvgMarkup], { type: 'image/svg+xml;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const trigger = document.createElement('a');
        trigger.href = url;
        trigger.download = 'crisp-qr-code.svg';
        document.body.appendChild(trigger);
        trigger.click();
        document.body.removeChild(trigger);
        URL.revokeObjectURL(url);
      });

      // Run initial generate setup pass
      generateCustomQR();
    });
  </script>

  <style>
    /* Clean layout styling matching your exact UI specifications */
    body {
      font-family: system-ui, -apple-system, sans-serif;
      background-color: #f9fafb;
      margin: 0;
      padding: 2rem;
      display: flex;
      justify-content: center;
    }

    .container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
      max-width: 800px;
      width: 100%;
      background: #ffffff;
      padding: 2rem;
      border-radius: 16px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    }

    .left-panel, .right-panel {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .input-group, .style-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    input[type="text"] {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1.5px solid #e5e7eb;
      border-radius: 10px;
      font-size: 1rem;
      box-sizing: border-box;
      outline: none;
      transition: border-color 0.2s;
    }

    input[type="text"]:focus {
      border-color: #4f46e5;
    }

    .style-buttons {
      display: flex;
      gap: 0.75rem;
    }

    .style-btn {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0.75rem;
      background: #fff;
      border: 1.5px solid #e5e7eb;
      border-radius: 10px;
      cursor: pointer;
      color: #4b5563;
      transition: all 0.2s;
    }

    .style-btn:hover {
      background: #f9fafb;
      border-color: #d1d5db;
    }

    .style-btn.active {
      background: #eff6ff;
      border-color: #3b82f6;
      color: #3b82f6;
    }

    .download-btn {
      margin-top: auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      background-color: #111827;
      color: white;
      border: none;
      padding: 0.85rem 1.5rem;
      border-radius: 10px;
      font-size: 1rem;
      font-weight: 500;
      cursor: pointer;
      transition: background-color 0.2s;
    }

    .download-btn:hover {
      background-color: #1f2937;
    }

    /* Target Screenshot Class Specifications */
    .preview-label {
      color: #9ca3af;
      text-transform: uppercase;
      letter-spacing: .08em;
      margin-bottom: .875rem;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .qr-preview {
      width: 100%;
      aspect-ratio: 1;
      border-radius: 14px;
      border: 1.5px solid #e5e7eb;
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      box-shadow: 0 2px 12px rgba(0,0,0,.05);
    }

    .qr-preview svg {
      width: 100%;
      height: auto;
      display: block;
    }

    .qr-placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: .875rem;
      padding: 2rem;
      width: 100%;
      aspect-ratio: 1;
      border-radius: 14px;
      border: 1.5px dashed #e5e7eb;
      box-sizing: border-box;
    }

    .qr-placeholder p {
      font-size: .8rem;
      color: #9ca3af;
      text-align: center;
      margin: 0;
    }

    .hidden {
      display: none !important;
    }

    /* Responsive Viewport Overrides */
    @media (max-width: 640px) {
      .container {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
      .left-panel {
        border-right: none;
        border-bottom: 1px solid #f1f5f9;
        padding-bottom: 1.5rem;
      }
      .right-panel {
        padding-top: 1.5rem;
      }
    }
  </style>
</body>
</html>
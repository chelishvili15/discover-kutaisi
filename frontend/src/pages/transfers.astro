---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BookingForms from "@/components/BookingForms.astro";
import StructuredData from "@/components/StructuredData.astro";
import { transfersIndexPage } from "@/data/pages";
import { site } from "@/data/site";
import {
  getTransferFromPriceGel,
  hasTransferPricingRow,
  transferFeatures,
  transferPricingTable,
  transferTours,
  vehicleTypes
} from "@/data/transfers";
import { icons } from "@/data/icons";
import { formatUsdGel } from "@/lib/currency";
import { buildBreadcrumbSchema, toAbsoluteUrl } from "@/lib/seo";
const { seo, content } = transfersIndexPage;
const siteUrl = `https://${site.domain}`;
const canonicalUrl = toAbsoluteUrl(seo.canonicalPath, siteUrl);
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: "Home", url: siteUrl },
  { name: "Transfers", url: canonicalUrl }
]);
const popularTransferTours = transferTours.filter((tour) => hasTransferPricingRow(tour));

const formatGelCell = (value?: string): string => {
  if (!value?.trim()) {
    return "-";
  }
  if (/^\d+(\.\d+)?$/.test(value.trim())) {
    return formatUsdGel(Number(value.trim()));
  }
  return value;
};
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonicalPath={seo.canonicalPath}
  image={seo.image}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  ogImage={seo.ogImage}
>
  <StructuredData data={breadcrumbSchema} />
  <section
    class="hero-bg hero-image-default hero-overlay-45 relative overflow-hidden py-20"
    
  >
    <div class="container-shell relative text-white">
      <h1 class="section-title !text-white">{content.heroTitle}</h1>
      <p class="mt-3 max-w-2xl text-sm text-gray-100">{content.heroSubtitle}</p>
    </div>
  </section>

  <section class="container-shell pt-12 pb-4">
    <div class="grid gap-8 md:grid-cols-2">
      <article class="rounded-xl border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-semibold text-brandDark">{content.popularToursTitle}</h2>
        <ul class="mt-4 space-y-2">
          {
            popularTransferTours.map((tour) => (
              <li class="flex items-center gap-3 rounded-lg border border-gray-200 px-3 py-2">
                <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center">
                  <img src={icons.transfers.popularRoutes} alt="Popular route" class="h-6 w-6 object-contain" loading="lazy" />
                </span>
                <div class="flex-1 text-sm">
                  <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2">
                    <span class="font-semibold text-gray-900">{tour.from}</span>
                    <span class="inline-flex justify-self-center" aria-hidden="true">
                      <img src={icons.transfers.tourDirection} alt="Direction arrow" class="h-4 w-4 object-contain" loading="lazy" />
                    </span>
                    <span class="justify-self-end font-semibold text-gray-900">{tour.to}</span>
                  </div>
                  <div class="mt-1 flex items-center justify-between text-xs">
                    <span class="text-gray-600">Duration: <span class="font-medium text-gray-800">{tour.duration}</span></span>
                    <span class="text-gray-600">From: <span class="font-semibold text-brandOrange">{formatUsdGel(getTransferFromPriceGel(tour))}</span></span>
                  </div>
                </div>
              </li>
            ))
          }
        </ul>
      </article>
      <article class="rounded-xl border border-gray-200 bg-white p-6">
        <h2 class="text-xl font-semibold">{content.serviceFeaturesTitle}</h2>
        <ul class="mt-4 space-y-3 text-sm text-gray-700">
          {
            transferFeatures.slice(0, 4).map((item) => (
              <li class="flex items-center gap-3 rounded-lg border border-gray-100 px-3 py-2">
                <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center">
                  <img src={icons.transfers.serviceFeatures} alt={item.title} class="h-6 w-6 object-contain" loading="lazy" />
                </span>
                <div>
                  <p class="text-base font-semibold text-gray-900">{item.title}</p>
                  <p class="text-xs text-gray-500">{item.description}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </article>
    </div>
  </section>

  {
    transferPricingTable && (
      <section class="container-shell pt-2 pb-4">
        <article class="rounded-xl border border-gray-200 bg-white p-6">
          <h2 class="text-2xl font-semibold text-brandDark">{transferPricingTable.title}</h2>
          <div class="mt-4 overflow-x-auto">
            <table class="min-w-[700px] w-full border-collapse text-left text-sm">
              <thead>
                <tr class="border-b border-gray-200 bg-gray-50">
                  <th class="px-4 py-3 font-semibold text-gray-900">{transferPricingTable.columnRoute}</th>
                  <th class="px-4 py-3 font-semibold text-gray-900">{transferPricingTable.column1To3}</th>
                  <th class="px-4 py-3 font-semibold text-gray-900">{transferPricingTable.column4To7}</th>
                  <th class="px-4 py-3 font-semibold text-gray-900">{transferPricingTable.column7Plus}</th>
                </tr>
              </thead>
              <tbody>
                {transferPricingTable.rows.map((row) => (
                  <tr class="border-b border-gray-100 last:border-0">
                    <td class="px-4 py-3 font-medium text-gray-900">{row.route}</td>
                    <td class="px-4 py-3 text-gray-900">{formatGelCell(row.price1To3)}</td>
                    <td class="px-4 py-3 text-gray-900">{formatGelCell(row.price4To7)}</td>
                    <td class="px-4 py-3 text-gray-900">{formatGelCell(row.price7Plus ?? "Price on request")}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          {transferPricingTable.note && <p class="mt-4 text-sm text-gray-600">{transferPricingTable.note}</p>}
        </article>
      </section>
    )
  }

  <section class="container-shell py-4">
    <div class="grid gap-8 md:grid-cols-2">
      <article class="rounded-xl border border-gray-200 bg-white p-6">
        <h2 class="text-xl font-semibold">{content.vehicleTypesTitle}</h2>
        <ul class="mt-4 space-y-3 text-sm text-gray-700">
          {
            vehicleTypes.map((item) => (
              <li class="flex items-center gap-3 rounded-lg border border-gray-100 px-3 py-2">
                <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center">
                  <img
                    src={item.title.includes("Sedan")
                      ? icons.transfers.vehicleTypes.sedan
                      : item.title.includes("Minivan")
                        ? icons.transfers.vehicleTypes.minivan
                        : icons.transfers.vehicleTypes.minibus}
                    alt={item.title}
                    class="h-6 w-6 object-contain"
                    loading="lazy"
                  />
                </span>
                <div>
                  <p class="text-base font-semibold text-gray-900">{item.title}</p>
                  <p class="text-xs text-gray-500">{item.description}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </article>
      <article>
        <BookingForms mode="transfer" />
      </article>
    </div>
  </section>
</BaseLayout>


